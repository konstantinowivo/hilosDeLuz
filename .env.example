# Sanity CMS Configuration
# Obtén estos valores en https://www.sanity.io/manage
VITE_SANITY_PROJECT_ID=tu_project_id_aqui
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01

# WhatsApp
VITE_WHATSAPP_NUMBER=5491234567890

# Social Media
VITE_INSTAGRAM_URL=https://www.instagram.com/tu_usuario
VITE_FACEBOOK_URL=https://www.facebook.com/tu_pagina

# Contact
VITE_CONTACT_EMAIL=contacto@tudominio.com

# Sanity Studio (solo para desarrollo del Studio)
# Estas NO necesitan el prefijo VITE_ porque solo se usan en el backend del Studio
SANITY_STUDIO_PROJECT_ID=tu_project_id_aqui
SANITY_STUDIO_DATASET=production
